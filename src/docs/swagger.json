          },
          "administrador": {
            "type": "object",
            "nullable": true,
            "properties": {
              "id": {
                "type": "integer"
              },
              "nome": {
                "type": "string",
                "nullable": true
              },
              "email": {
                "type": "string",
                "format": "email"
              },
              "tipo": {
                "type": "string",
                "nullable": true
              }
            }
          }
        }
      },
      "PagedNoticiaResponse": {
        "type": "object",
        "properties": {
          "dados": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Noticia"
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "pagina": {
                "type": "integer"
              },
              "limite": {
                "type": "integer"
              },
              "total": {
                "type": "integer"
              },
              "total_paginas": {
                "type": "integer"
              }
            }
          }
        }
      },
      "CreateGlossarioInput": {
        "type": "object",
        "required": [
          "termo",
          "definicao"
        ],
        "properties": {
          "termo": {
            "type": "string",
            "minLength": 2,
            "maxLength": 120,
            "example": "Foco de incendio"
          },
          "definicao": {
            "type": "string",
            "minLength": 5,
            "maxLength": 3000,
            "example": "Registro detectado por satelite indicando possivel ocorrencia de fogo."
          }
        }
      },
      "UpdateGlossarioInput": {
        "type": "object",
        "properties": {
          "termo": {
            "type": "string",
            "minLength": 2,
            "maxLength": 120
          },
          "definicao": {
            "type": "string",
            "minLength": 5,
            "maxLength": 3000
          }
        }
      },
      "Glossario": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "termo": {
            "type": "string"
          },
          "definicao": {
            "type": "string"
          }
        }
      },
      "PagedGlossarioResponse": {
        "type": "object",
        "properties": {
          "dados": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Glossario"
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "pagina": {
                "type": "integer"
              },
              "limite": {
                "type": "integer"
              },
              "total": {
                "type": "integer"
              },
              "total_paginas": {
                "type": "integer"
              }
            }
          }
        }
      },
      "AuthRegisterInput": {
        "type": "object",
        "required": [
          "nome",
          "email",
          "telefone",
          "id_regiao",
          "senha"
        ],
        "properties": {
          "nome": {
            "type": "string",
            "minLength": 2,
            "maxLength": 120,
            "example": "Maria da Silva"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "usuario@exemplo.com"
          },
          "telefone": {
            "type": "string",
            "example": "+55 (31) 99999-9999"
          },
          "id_regiao": {
            "type": "integer",
            "minimum": 1,
            "example": 5
          },
          "senha": {
            "type": "string",
            "minLength": 6,
            "maxLength": 72,
            "example": "senha123"
          }
        }
      },
      "AuthLoginInput": {
        "type": "object",
        "required": [
          "email",
          "senha"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "usuario@exemplo.com"
          },
          "senha": {
            "type": "string",
            "example": "senha123"
          }
        }
      },
      "AuthUsuario": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "nome": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "telefone": {
            "type": "string",
            "nullable": true
          },
          "tipo": {
            "type": "string",
            "nullable": true
          },
          "id_regiao": {
            "type": "integer",
            "nullable": true
          },
          "data_cadastro": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "AuthSuccessResponse": {
        "type": "object",
        "properties": {
          "usuario": {
            "$ref": "#/components/schemas/AuthUsuario"
          },
          "token": {
            "type": "string",
            "description": "JWT de acesso"
          }
        }
      },
      "AuthForgotPasswordInput": {
        "type": "object",
        "required": [
          "email"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "usuario@exemplo.com"
          }
        }
      },
      "AuthResetPasswordInput": {
        "type": "object",
        "required": [
          "token",
          "senha"
        ],
        "properties": {
          "token": {
            "type": "string",
            "description": "Token de redefinicao recebido no fluxo de recuperacao"
          },
          "senha": {
            "type": "string",
            "minLength": 6,
            "maxLength": 72,
            "example": "novaSenha123"
          }
        }
      },
      "MessageResponse": {
        "type": "object",
        "properties": {
          "mensagem": {
            "type": "string"
          }
        }
      },
      "ForgotPasswordResponse": {
        "type": "object",
        "properties": {
          "mensagem": {
            "type": "string"
          },
          "token_reset": {
            "type": "string",
            "nullable": true,
            "description": "Retornado apenas fora de producao para facilitar testes"
          },
          "link_reset": {
            "type": "string",
            "nullable": true
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Requisicao invalida",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "NotFound": {
        "description": "Recurso nao encontrado",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Unauthorized": {
        "description": "Nao autenticado",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      },
      "Forbidden": {
        "description": "Acesso negado",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        }
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
