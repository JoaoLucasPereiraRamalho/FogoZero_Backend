    "/api/auth/logout": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Encerra a sessao do usuario autenticado",
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Logout realizado",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/auth/forgot-password": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Solicita recuperacao de senha",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthForgotPasswordInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Instrucao de recuperacao processada",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ForgotPasswordResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/api/auth/reset-password": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Redefine a senha com token temporario",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AuthResetPasswordInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Senha redefinida",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MessageResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateReporteInput": {
        "type": "object",
        "required": [
          "assunto",
          "latitude",
          "longitude",
          "imagem_url"
        ],
        "properties": {
          "assunto": {
            "type": "string",
            "minLength": 5,
            "maxLength": 1000,
            "example": "Foco de incendio proximo a area de mata"
          },
          "latitude": {
            "type": "number",
            "minimum": -90,
            "maximum": 90,
            "example": -19.9245
          },
          "longitude": {
            "type": "number",
            "minimum": -180,
            "maximum": 180,
            "example": -43.9352
          },
          "imagem_url": {
            "type": "string",
            "format": "uri",
            "example": "https://cdn.exemplo.com/imagens/reporte-123.jpg"
          },
          "id_status_analise_ia": {
            "type": "integer",
            "minimum": 1,
            "example": 1
          },
          "id_status_analise_admin": {
            "type": "integer",
            "minimum": 1,
            "example": 2
          }
        }
      },
      "UpdateStatusAdminInput": {
        "type": "object",
        "required": [
          "id_status_analise_admin"
        ],
        "properties": {
          "id_status_analise_admin": {
            "type": "integer",
            "minimum": 1,
            "example": 3
          }
        }
      },
      "ForwardReporteInput": {
        "type": "object",
        "required": [
          "id_status_analise_admin"
        ],
        "properties": {
          "id_status_analise_admin": {
            "type": "integer",
            "minimum": 1,
            "example": 4
          }
        }
      },
      "Reporte": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "usuario_id": {
            "type": "integer"
          },
          "assunto": {
            "type": "string"
          },
          "latitude": {
            "type": "number"
          },
          "longitude": {
            "type": "number"
          },
          "imagem_url": {
            "type": "string",
            "format": "uri"
          },
          "id_status_analise_ia": {
            "type": "integer",
            "nullable": true
          },
          "id_status_analise_admin": {
            "type": "integer",
            "nullable": true
          },
          "data_reporte": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "usuario": {
            "$ref": "#/components/schemas/UsuarioResumo"
          },
          "status_analise_ia": {
            "$ref": "#/components/schemas/StatusResumo"
          },
          "status_analise_admin": {
            "$ref": "#/components/schemas/StatusResumo"
          }
        }
      },
      "UsuarioResumo": {
        "type": "object",
        "nullable": true,
        "properties": {
          "id": {
            "type": "integer"
          },
          "nome": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "tipo": {
            "type": "string",
            "nullable": true
          },
          "id_regiao": {
            "type": "integer",
            "nullable": true
          }
        }
      },
      "StatusResumo": {
        "type": "object",
        "nullable": true,
        "properties": {
          "id": {
            "type": "integer"
          },
          "descricao": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "PagedReporteResponse": {
        "type": "object",
        "properties": {
          "dados": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Reporte"
            }
          },
          "meta": {
            "type": "object",
            "properties": {
              "pagina": {
                "type": "integer"
              },
              "limite": {
                "type": "integer"
              },
              "total": {
                "type": "integer"
              },
              "total_paginas": {
                "type": "integer"
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "mensagem": {
            "type": "string"
          },
          "detalhes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "campo": {
                  "type": "string"
                },
                "mensagem": {
                  "type": "string"
                }
              }
            }
          }
        }
      },
      "CreateNoticiaInput": {
        "type": "object",
