            "type": "string",
            "minLength": 3,
            "maxLength": 200
          },
          "link_origem": {
            "type": "string",
            "format": "uri"
          },
          "img_destaque_url": {
            "type": "string",
            "format": "uri"
          }
        }
      },
      "Noticia": {
        "type": "object",
        "properties": {
