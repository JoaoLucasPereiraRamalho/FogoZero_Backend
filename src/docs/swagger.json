{
  "openapi": "3.0.3",
  "info": {
    "title": "FogoZero Backend API",
    "version": "1.0.0",
    "description": "Documentacao da API do sistema back-end do FogoZero"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Ambiente local"
    }
  ],
  "tags": [
    {
      "name": "Health",
      "description": "Endpoints de status da API"
    },
    {
      "name": "Reportes",
      "description": "Endpoints do modulo de reporte comunitario"
    },
    {
      "name": "Educativo",
      "description": "Endpoints do modulo educativo (noticias e glossario)"
    },
    {
      "name": "Auth",
      "description": "Endpoints de autenticacao e cadastro"
    }
  ],
  "paths": {
    "/ping": {
      "get": {
        "tags": [
          "Health"
        ],
        "summary": "Verifica se a API esta online",
        "responses": {
          "200": {
            "description": "API online",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "mensagem": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string",
                      "example": "online"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/reportes": {
      "post": {
        "tags": [
          "Reportes"
        ],
        "summary": "Cria um novo reporte",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateReporteInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Reporte criado com sucesso",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "reporte": {
                      "$ref": "#/components/schemas/Reporte"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      },
      "get": {
        "tags": [
          "Reportes"
        ],
        "summary": "Lista reportes com filtros e paginacao",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "default": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            }
          },
          {
            "name": "usuario_id",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "id_status_analise_ia",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          },
          {
            "name": "id_status_analise_admin",
            "in": "query",
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista paginada de reportes",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PagedReporteResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
