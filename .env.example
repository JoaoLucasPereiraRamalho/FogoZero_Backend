# ─────────────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env com valores reais no repositório.
# ─────────────────────────────────────────────────────────────────

# Banco de dados local (usado pelo Docker Compose)
DB_USER=postgres
DB_PASSWORD=CHANGE_ME
DB_NAME=fogozero

# URL de conexão — em desenvolvimento local sem Docker, aponta para localhost
# Em Docker Compose, o host é o nome do serviço "db"
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/fogozero

# JWT
JWT_SECRET=CHANGE_ME_use_uma_string_longa_e_aleatoria
JWT_EXPIRATION=24h

# Bcrypt — recomendado entre 10 e 14 em produção
BCRYPT_ROUNDS=10

# Ambiente
NODE_ENV=development
PORT=3000

# Supabase (armazenamento de gráficos e mapas — externo, somente SUPABASE_URL é usada)
SUPABASE_URL=https://seu-projeto.supabase.co

# Microserviço de IA (análise de imagens de incêndio)
# Em Docker Compose com serviço ia: http://ia:8000
# Em produção: URL pública do serviço Python
IA_SERVICE_URL=http://localhost:8000

# URL do frontend (usada no link de reset de senha enviado por email)
FRONTEND_URL=http://localhost:5173
