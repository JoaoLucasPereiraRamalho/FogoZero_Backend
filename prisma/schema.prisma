generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id            Int       @id @default(autoincrement())
  nome          String?
  email         String    @unique
  telefone      String?
  senha_hash    String
  tipo          String?
  id_regiao     Int?
  data_cadastro DateTime? @default(now())
  reportes      Reporte[]
  noticias      Noticia[]
  monitoramentos Monitoramento[]
  notificacoes  Notificacao[]

  @@map("usuario")
}

model Reporte {
  id                      Int       @id @default(autoincrement())
  usuario_id              Int
  assunto                 String?
  latitude                Float?
  longitude               Float?
  imagem_url              String?
  id_status_analise_ia    Int?
  id_status_analise_admin Int?
  data_reporte            DateTime? @default(now())
  usuario                 Usuario             @relation(fields: [usuario_id], references: [id])
  status_analise_ia       StatusAnaliseIa?    @relation(fields: [id_status_analise_ia], references: [id])
  status_analise_admin    StatusAnaliseAdmin? @relation(fields: [id_status_analise_admin], references: [id])

  @@map("reporte")
}

model Regiao {
  id                 Int       @id @default(autoincrement())
  nome               String?
  id_tipo_regiao     Int?
  tipo_regiao        TipoRegiao?        @relation(fields: [id_tipo_regiao], references: [id])
  registros_queimada RegistroQueimada[]

  @@map("regiao")
}

model RegistroQueimada {
  id               Int       @id @default(autoincrement())
  id_regiao        Int?
  data_registro    DateTime?
  quantidade_focos Int?
  fonte_dados      String?
  regiao           Regiao?   @relation(fields: [id_regiao], references: [id])

  @@map("registro_queimada")
}


model Glossario {
  id        Int    @id @default(autoincrement())
  termo     String
  definicao String

  @@map("glossario")
}

model StatusAnaliseIa {
  id        Int       @id @default(autoincrement())
  descricao String?
  reportes  Reporte[]

  @@map("status_analise_ia")
}

model StatusAnaliseAdmin {
  id        Int       @id @default(autoincrement())
  descricao String?
  reportes  Reporte[]

  @@map("status_analise_admin")
}

model TipoRegiao {
  id        Int      @id @default(autoincrement())
  descricao String?
  regioes   Regiao[]

  @@map("tipo_regiao")
}

enum StatusNoticia {
  PENDENTE   // Aguardando análise do ADM
  APROVADA   // Visível no portal para usuários
  REJEITADA  // Descartada pelo ADM
}

model Noticia {
  id               Int           @id @default(autoincrement())
  titulo           String
  slug             String        @unique
  conteudo         String        @db.Text
  imagem_capa      String?
  fonte_url        String?       
  status           StatusNoticia @default(PENDENTE)
  data_importacao  DateTime      @default(now())
  data_publicacao  DateTime?
  autor_id         Int
  autor            Usuario       @relation(fields: [autor_id], references: [id])

  @@map("noticias")
}

model Monitoramento {
  id          Int      @id @default(autoincrement())
  usuarioId   Int
  cidade      String   // Nome da cidade (ex: "Lagoa da Prata")
  estado      String   @default("MG")
  notificar   Boolean  @default(true)
  createdAt   DateTime @default(now())

  usuario     Usuario  @relation(fields: [usuarioId], references: [id])

  @@unique([usuarioId, cidade])
}

model Notificacao {
  id          Int       @id @default(autoincrement())
  usuarioId   Int
  tipo        String    // QUEIMADA, NOTICIA, REPORTE
  titulo      String
  descricao   String    @db.Text
  cidade      String
  lido        Boolean   @default(false)
  criadoEm    DateTime  @default(now())

  usuario     Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([lido])
  @@map("notificacoes")
model MunicipioMG {
  id                  Int      @id @default(autoincrement())
  municipio           String   @unique
  numero_focos        Int?
  lat                 Float?
  lon                 Float?
  imri                Float?
  classificacao_imri  String?
  bioma_mais_afetado  String?
  mes_mais_afetado    String?
  focos_2015          Int?
  focos_2016          Int?
  focos_2017          Int?
  focos_2018          Int?
  focos_2019          Int?
  focos_2020          Int?
  focos_2021          Int?
  focos_2022          Int?
  focos_2023          Int?
  focos_2024          Int?
  focos_2025          Int?
}