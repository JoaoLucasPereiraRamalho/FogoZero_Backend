generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id            Int       @id @default(autoincrement())
  nome          String?
  email         String    @unique
  tipo          String?
  id_regiao     Int?
  data_cadastro DateTime? @default(now())
  reportes      Reporte[]
  noticias      Noticia[]

  @@map("usuario")
}

model Reporte {
  id                      Int       @id @default(autoincrement())
  usuario_id              Int
  assunto                 String?
  latitude                Float?
  longitude               Float?
  imagem_url              String?
  id_status_analise_ia    Int?
  id_status_analise_admin Int?
  data_reporte            DateTime? @default(now())
  usuario                 Usuario             @relation(fields: [usuario_id], references: [id])
  status_analise_ia       StatusAnaliseIa?    @relation(fields: [id_status_analise_ia], references: [id])
  status_analise_admin    StatusAnaliseAdmin? @relation(fields: [id_status_analise_admin], references: [id])

  @@map("reporte")
}

model Regiao {
  id                 Int       @id @default(autoincrement())
  nome               String?
  id_tipo_regiao     Int?
  tipo_regiao        TipoRegiao?        @relation(fields: [id_tipo_regiao], references: [id])
  registros_queimada RegistroQueimada[]

  @@map("regiao")
}

model RegistroQueimada {
  id               Int       @id @default(autoincrement())
  id_regiao        Int?
  data_registro    DateTime?
  quantidade_focos Int?
  fonte_dados      String?
  regiao           Regiao?   @relation(fields: [id_regiao], references: [id])

  @@map("registro_queimada")
}

model Noticia {
  id               Int       @id @default(autoincrement())
  titulo           String
  link_origem      String
  img_destaque_url String?
  adm_id           Int
  data_publicacao  DateTime? @default(now())
  administrador    Usuario   @relation(fields: [adm_id], references: [id])

  @@map("noticia")
}

model Glossario {
  id        Int    @id @default(autoincrement())
  termo     String
  definicao String

  @@map("glossario")
}

model StatusAnaliseIa {
  id        Int       @id @default(autoincrement())
  descricao String?
  reportes  Reporte[]

  @@map("status_analise_ia")
}

model StatusAnaliseAdmin {
  id        Int       @id @default(autoincrement())
  descricao String?
  reportes  Reporte[]

  @@map("status_analise_admin")
}

model TipoRegiao {
  id        Int      @id @default(autoincrement())
  descricao String?
  regioes   Regiao[]

  @@map("tipo_regiao")
}